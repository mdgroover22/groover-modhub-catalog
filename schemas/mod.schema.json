{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/groover-modhub/mod.schema.json",
  "title": "Groover Mod Hub Mod",
  "type": "object",
  "required": ["id", "name", "author", "version", "game", "category", "files"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "name": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "game": {
      "type": "string",
      "enum": ["ets2", "ats"]
    },
    "category": {
      "type": "string"
    },
    "description_short": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "cover_image": {
      "type": "string"
    },
    "gallery": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "game_versions": {
      "type": "object",
      "properties": {
        "min": { "type": "string" },
        "max": { "type": "string" }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "dependency.schema.json"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "file.schema.json"
      }
    },
    "changelog_url": {
      "type": "string"
    }
  }
}
